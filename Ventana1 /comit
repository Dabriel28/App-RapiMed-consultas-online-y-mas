# VENTANA 1: 
# ==========================================
class VentanaRegistro(QWidget):
    def __init__(self, main_window):
        super().__init__()
        self.main = main_window
        #self.setWindowTitle("Paso 1: Registro")
        
        layout = QVBoxLayout()
        subtitulo = QLabel("Bienvenido/a a RapiMed donde podrás agendar tu cita medica, solicitar medicamentos o pedir una ambulancia en caso de ser necesario de forma rapida y sencilla. Contamos con un equipo de profesionales altamente capacitados y comprometidos con tu bienestar. ¡Tu salud es nuestra prioridad!")
        titulo = QLabel("🏥 RapiMed")
        titulo.setFont(QFont("Segoe UI", 20, QFont.Bold))
        titulo.setAlignment(Qt.AlignCenter)
        subtitulo.setAlignment(Qt.AlignCenter)
        subtitulo.setWordWrap(True)
        self.input_nombre = QLineEdit()
        self.input_nombre.setPlaceholderText("Nombre completo")
        self.input_cedula = QLineEdit()
        self.input_cedula.setPlaceholderText("Cédula o ID")
        self.input_telefono = QLineEdit()
        self.input_telefono.setPlaceholderText("Teléfono")
        
        btn_siguiente = QPushButton("Continuar ->")
        btn_siguiente.clicked.connect(self.validar_y_continuar)  
          
        layout.addStretch()
        layout.addWidget(subtitulo) 
        layout.addWidget(titulo)  
        layout.addSpacing(20)  
        layout.addWidget(QLabel("Nombre completo:"))  
        layout.addWidget(self.input_nombre)  
        layout.addWidget(QLabel("Documento de Identidad:"))  
        layout.addWidget(self.input_cedula)  
        layout.addWidget(QLabel("Teléfono de contacto:"))  
        layout.addWidget(self.input_telefono)  
        layout.addSpacing(20)  
        layout.addWidget(btn_siguiente)  
        layout.addStretch()  
          
        self.setLayout(layout)  
  
    def validar_y_continuar(self):  
        nombre = self.input_nombre.text()  
        cedula = self.input_cedula.text()  
        telefono = self.input_telefono.text()  
          
        if nombre == "" or cedula == "" or telefono == "":  
            QMessageBox.warning(self, "Error", "Por favor, complete todos los campos.")  
            return  
              
        self.main.datos_paciente = {  
            "nombre": nombre,  
            "cedula": cedula,  
            "telefono": telefono  
        }  
        self.main.stack.setCurrentIndex(1)
